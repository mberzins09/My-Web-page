@page "/login"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">🔐 Login</h3>
                <input class="form-control mb-3" @bind="email"
                       placeholder="Email" type="email" />
                <input class="form-control mb-3" @bind="password"
                       placeholder="Password" type="password" />
                <button class="btn btn-primary w-100" @onclick="HandleLogin">
                    Login
                </button>
                @if (message != null)
                {
                    <p class="mt-3 text-danger text-center">@message</p>
                }
                <hr />
                <p class="text-center text-muted mb-0">
                    Don't have an account?
                    <a href="/register">Register here</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    string email = "", password = "";
    string? message;

    async Task HandleLogin()
    {
        bool success = await JS.InvokeAsync<bool>("loginUser", email, password);

        if (success)
        {
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            message = "Invalid credentials.";
        }
    }
}