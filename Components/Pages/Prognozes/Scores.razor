@page "/prognozes/{Slug}/scores"
@rendermode InteractiveServer
@using MartinsWeb.Services
@using MartinsWeb.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject GameService GameService
@inject UserContextService UserContext
@inject AuthenticationStateProvider AuthStateProvider

<h3>⚽ Scores — @(tournament?.Name ?? "...")</h3>

@if (tournament == null)
{
    <p class="text-danger">Tournament not found.</p>
}
else if (matches == null)
{
    <p>Loading...</p>
}
else if (!matches.Any())
{
    <p>No matches added yet.</p>
}
else
{
    <div class="mb-3 d-flex flex-wrap gap-2">
        <button class="btn btn-sm @(selectedStage == null ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => selectedStage = null">
            All
        </button>
        @foreach (var stage in stages)
        {
            <button class="btn btn-sm @(selectedStage == stage ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => selectedStage = stage">
                @stage
            </button>
        }
    </div>

    @if (currentUserGroups.Count > 1)
    {
        <div class="mb-3 d-flex align-items-center gap-2">
            <label class="text-white-50 mb-0" style="font-size:.85rem">View points as:</label>
            <select class="form-select form-select-sm bg-dark text-white border-secondary"
                    style="max-width:220px"
                    @onchange="OnViewGroupChanged">
                <option value="">— tournament default —</option>
                @foreach (var g in currentUserGroups)
                {
                    <option value="@g.Id" selected="@(selectedViewGroup?.Id == g.Id)">
                        @g.Name (@(g.PointsCalculationType ?? tournament!.PointsCalculationType))
                    </option>
                }
            </select>
        </div>
    }

    @if (!filteredGames.Any())
    {
        <p>No games in this stage yet.</p>
    }
    else
    {
        <div class="tt-grid pred-grid">
            @foreach (var match in filteredGames)
            {
                <div class="tt-card pred-card">
                    <div class="pred-card-top">
                        <span class="pred-date">@match.GameDate.ToString("MMM dd HH:mm")</span>
                        <span class="pred-match">@match.HomeTeam vs @match.AwayTeam</span>
                        <span class="pred-stage">@match.Stage</span>
                    </div>
                    <div class="pred-card-bottom">
                        <span class="pred-input-col">
                            @{
                                // What to show as the result depends on selected group's calc type
                                var viewCalcType = PredictionHelper.ResolveCalcType(currentUserGroup, tournament!);
                                var isFtViewType = viewCalcType == "Football" || viewCalcType == "Football3";
                                var isPlayoffMatch = PredictionHelper.IsPlayoffStage(match.Stage);
                                bool showFtResult = isFtViewType && isPlayoffMatch
                    && (match.HomeFullTimeScore != null || match.AwayFullTimeScore != null)
                    && !(match.HomeFullTimeScore == 0 && match.AwayFullTimeScore == 0 && match.HomeScore == null);
                            }
                            @if (showFtResult)
                            {
                                <strong>@match.HomeFullTimeScore : @match.AwayFullTimeScore <span class="text-white-50" style="font-size:.75rem">(FT)</span></strong>
                            }
                            else if (match.HomeScore != null)
                            {
                                <strong>@match.HomeScore : @match.AwayScore@(match.IsOvertime ? " OT" : "")</strong>
                            }
                            else
                            {
                                <span class="text-white">TBD</span>
                            }
                        </span>
                        <span class="pred-right-col">
                            @if (match.GameDate < PredictionHelper.LatviaTime && allUserPredictions.Any())
                            {
                                <button class="btn btn-sm btn-outline-secondary p-0 px-2"
                                        style="font-size:.8rem; line-height:1.6"
                                        title="Show predictions"
                                        @onclick="() => TogglePredictions(match.Id)">
                                    @(expandedGameIds.Contains(match.Id) ? "▲" : "▼")
                                </button>
                            }
                            <AuthorizeView Roles="Admin">
                                @{
                                    var resolvedCalcType = PredictionHelper.ResolveCalcType(currentUserGroup, tournament!);
                                    var canOT = PredictionHelper.CanHaveOT(match, resolvedCalcType,
                                                        scoreInputs[match.Id].Home - scoreInputs[match.Id].Away);
                                    var showFtRow = tournamentNeedsFullTime && PredictionHelper.IsPlayoffStage(match.Stage);
                                }
                                <div class="d-flex flex-column gap-1">

                                    @* Main score row *@
                                    <div class="d-flex align-items-center gap-1 flex-nowrap">
                                        @if (showFtRow)
                                        {
                                            <small class="text-white-50" style="font-size:.75rem">OT:</small>
                                        }
                                        <input class="form-control pred-score-input" type="number" min="0" max="20"
                                               value="@scoreInputs[match.Id].Home"
                                               @onchange="async e => {
                                                   scoreInputs[match.Id].Home = PredictionHelper.ParseScore(e);
                                                   if (!PredictionHelper.CanHaveOT(match, resolvedCalcType,
                                                           scoreInputs[match.Id].Home - scoreInputs[match.Id].Away))
                                                       scoreInputs[match.Id].IsOvertime = false;
                                                   await AutoSaveScore(match.Id);
                                               }
                                               " />
                                        <span class="pred-colon">:</span>
                                        <input class="form-control pred-score-input" type="number" min="0" max="20"
                                               value="@scoreInputs[match.Id].Away"
                                               @onchange="async e => {
                                                   scoreInputs[match.Id].Away = PredictionHelper.ParseScore(e);
                                                   if (!PredictionHelper.CanHaveOT(match, resolvedCalcType,
                                                           scoreInputs[match.Id].Home - scoreInputs[match.Id].Away))
                                                       scoreInputs[match.Id].IsOvertime = false;
                                                   await AutoSaveScore(match.Id);
                                               }
                                               " />
                                        @if (canOT)
                                        {
                                            <div class="form-check form-check-inline ms-1 mb-0" title="Overtime?">
                                                <input class="form-check-input" type="checkbox" id="ot_@(match.Id)"
                                                       checked="@scoreInputs[match.Id].IsOvertime"
                                                       @onchange="async e => {
                                                           scoreInputs[match.Id].IsOvertime = (bool)(e.Value ?? false);
                                                           await AutoSaveScore(match.Id);
                                                       }
                                                       " />
                                                <label class="form-check-label small" for="ot_@(match.Id)">OT</label>
                                            </div>
                                        }
                                        @if (justSaved.Contains(match.Id))
                                        {
                                            <span class="text-success ms-1">✓</span>
                                        }
                                        else if (match.HomeScore == null)
                                        {
                                            <button class="btn btn-sm btn-outline-success ms-1 p-0 px-1"
                                                    style="font-size:.8rem; line-height:1.4"
                                                    title="Save score"
                                                    @onclick="async () => await AutoSaveScore(match.Id)">
                                                💾
                                            </button>
                                        }
                                    </div>

                                    @* Full-time score row — only for playoff games when tournament needs it *@
                                    @if (showFtRow)
                                    {
                                        <div class="d-flex align-items-center gap-1 flex-nowrap">
                                            <small class="text-white-50" style="font-size:.75rem">FT:</small>
                                            <input class="form-control pred-score-input" type="number" min="0" max="20"
                                                   value="@(scoreInputs[match.Id].HomeFullTime ?? 0)"
                                                   @onchange="async e => {
                                                       scoreInputs[match.Id].HomeFullTime = PredictionHelper.ParseScore(e);
                                                   }
                                                   " />
                                            <span class="pred-colon">:</span>
                                            <input class="form-control pred-score-input" type="number" min="0" max="20"
                                                   value="@(scoreInputs[match.Id].AwayFullTime ?? 0)"
                                                   @onchange="async e => {
                                                       scoreInputs[match.Id].AwayFullTime = PredictionHelper.ParseScore(e);
                                                   }
                                                   " />
                                            @* Save button instead of auto-save — handles 0:0 case *@
                                            @if (justSavedFT.Contains(match.Id))
                                            {
                                                <span class="text-success ms-1">✓</span>
                                            }
                                            else if (!ftSaved.Contains(match.Id))
                                            {
                                                <button class="btn btn-sm btn-outline-success ms-1 p-0 px-1"
                                                        style="font-size:.8rem; line-height:1.4"
                                                        title="Save full-time score"
                                                        @onclick="async () => await AutoSaveFT(match.Id)">
                                                    💾
                                                </button>
                                            }
                                        </div>
                                    }

                                </div>
                            </AuthorizeView>
                        </span>
                    </div>
                    @if (expandedGameIds.Contains(match.Id))
                    {
                        <div class="pred-expand">
                            @{
                                var gamePreds = allUserPredictions
                                    .Where(up => up.pred != null && up.pred.GameId == match.Id)
                                    .ToList();
                            }
                            @if (!gamePreds.Any())
                            {
                                <span class="text-white" style="font-size:.8rem">No predictions yet.</span>
                            }
                            else
                            {
                                <div style="font-size:.8rem; color:#ccc; margin-bottom:4px;">
                                    <span>@PredictionDistribution(gamePreds, match)</span>
                                </div>
                                <div style="font-size:.8rem; color:#aaa; margin-bottom:6px;">
                                    <span>@MostPopular(gamePreds, match)</span>
                                </div>
                                @foreach (var (user, pred, group) in gamePreds)
                                {
                                    var pts = match.HomeScore != null ? CalcPoints(pred!, match, group) : (int?)null;
                                    
                                    <div class="pred-expand-row">
                                        <span class="pred-expand-name">@user.Username</span>
                                        <span class="pred-expand-score">@pred!.PredictedHomeScore : @pred.PredictedAwayScore@(pred.PredictedIsOvertime ? " OT" : "")</span>
                                        @if (pts != null)
                                        {
                                            <span class="badge @PointsBadgeClass(pts.Value)">@pts</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    Tournament?  tournament;
    List<Game>?  matches;
    Dictionary<int, ScoreInput> scoreInputs = new();
    HashSet<int> justSaved      = new();
    HashSet<int> justSavedFT = new();
    HashSet<int> ftSaved = new();
    HashSet<int> expandedGameIds = new();
    string?      selectedStage;
    UserGroup? currentUserGroup;
    List<UserGroup> allTournamentGroups = new();   // NEW: all groups for this tournament
    bool tournamentNeedsFullTime = false;           // NEW: show FT inputs?
    UserGroup? selectedViewGroup;                   // NEW: viewer's selected group for calc type
    List<UserGroup> currentUserGroups = new();      // NEW: all groups current user belongs to

    // userId -> their predictions for this tournament (preloaded at init)
    List<(User user, Prediction? pred, UserGroup? group)> allUserPredictions = new();

    List<string> stages => matches?
        .Select(g => g.Stage)
        .Where(s => !string.IsNullOrEmpty(s))
        .Distinct()
        .OrderBy(StageOrder)
        .ToList() ?? new();

    List<Game> filteredGames => PredictionHelper.FilteredGames(matches, selectedStage);

    int StageOrder(string stage) => PredictionHelper.StageOrder(stage);

    int ParseScore(ChangeEventArgs e)
    {
        int.TryParse(e.Value?.ToString(), out var v);
        return Math.Max(0, Math.Min(20, v));
    }

    protected override async Task OnInitializedAsync()
    {
        tournament = await GameService.GetTournamentBySlugAsync(Slug);
        if (tournament == null) return;

        var userGroupsList = await GameService.GetUserGroupsByTournamentAsync(tournament.Id);

        allTournamentGroups = userGroupsList;
        tournamentNeedsFullTime = PredictionHelper.NeedsFullTimeScore(allTournamentGroups, tournament);


        matches = await GameService.GetMatchesByTournamentAsync(tournament.Id);
        foreach (var m in matches)
        {
            scoreInputs[m.Id] = new ScoreInput
                {
                    Home = m.HomeScore ?? 0,
                    Away = m.AwayScore ?? 0,
                    IsOvertime = m.IsOvertime,
                    HomeFullTime = m.HomeFullTimeScore,  // NEW
                    AwayFullTime = m.AwayFullTimeScore   // NEW
                };

            if (m.HomeFullTimeScore != null)
                ftSaved.Add(m.Id);
        }

        // Preload all group members' predictions so dropdown works without extra calls
        var currentUserId = await UserContext.GetUserIdAsync();

        if (currentUserId != null)
        {
            var currentUserGroups2 = await GameService.GetUserGroupsForUserAsync(currentUserId.Value, tournament.Id);
            currentUserGroup = currentUserGroups2.Count == 1 ? currentUserGroups2[0] : null;
            currentUserGroups = currentUserGroups2;
            allTournamentGroups = userGroupsList;
            tournamentNeedsFullTime = PredictionHelper.NeedsFullTimeScore(allTournamentGroups, tournament);

            var groupMates = await GameService.GetGroupMatesAsync(currentUserId.Value, tournament.Id);
            foreach (var user in groupMates)
            {
                var userGroup = userGroupsList.FirstOrDefault(g =>
                                                g.Members.Any(m => m.UserId == user.Id) &&
                                                g.Members.Any(m => m.UserId == currentUserId.Value));
                var preds = await GameService.GetUserPredictionsByTournamentAsync(user.Id, tournament.Id);
                foreach (var m in matches)
                {
                    var pred = preds.FirstOrDefault(p => p.GameId == m.Id);
                    allUserPredictions.Add((user, pred, userGroup));
                }
            }
        }
    }

    int CalcPoints(Prediction p, Game g, UserGroup? userGroup = null)
    {
        if (g.HomeScore == null || g.AwayScore == null) return 0;
        var calcType = PredictionHelper.ResolveCalcType(userGroup, tournament!);
        return PointsCalculator.Calculate(
            p.PredictedHomeScore, p.PredictedAwayScore, p.PredictedIsOvertime,
            g.HomeScore.Value, g.AwayScore.Value, g.IsOvertime,
            g.Stage, calcType, g.HomeFullTimeScore, g.AwayFullTimeScore);
    }

    string PointsBadgeClass(int pts) => PredictionHelper.PointsBadgeClass(pts, PredictionHelper.ResolveCalcType(currentUserGroup, tournament!));

    void TogglePredictions(int gameId)
    {
        if (!expandedGameIds.Remove(gameId))
            expandedGameIds.Add(gameId);
    }

    bool IsHockeyMode(Game match) => PredictionHelper.IsHockeyMode(match, tournament?.PointsCalculationType ?? "Football");

    string PredictionDistribution(List<(User user, Prediction? pred, UserGroup? userGroup)> preds, Game match) =>
    PredictionHelper.PredictionDistribution(preds, match, tournament?.PointsCalculationType ?? "Football");

    // Most popular prediction(s); "Unpredictable game" if all differ
    string MostPopular(List<(User user, Prediction? pred, UserGroup? userGroup)> preds, Game match) =>
    PredictionHelper.MostPopular(preds, match, tournament?.PointsCalculationType ?? "Football");

    async Task AutoSaveScore(int matchId)
    {
        var s = scoreInputs[matchId];
        await GameService.UpdateScoreAsync(matchId, s.Home, s.Away, s.IsOvertime, null, null);
        if (tournament != null)
            matches = await GameService.GetMatchesByTournamentAsync(tournament.Id);

        justSaved.Add(matchId);
        StateHasChanged();
        await Task.Delay(1500);
        justSaved.Remove(matchId);
        StateHasChanged();
    }

    void OnViewGroupChanged(ChangeEventArgs e)
    {
        int.TryParse(e.Value?.ToString(), out var id);
        selectedViewGroup = id == 0 ? null : currentUserGroups.FirstOrDefault(g => g.Id == id);
        currentUserGroup = selectedViewGroup;
    }

    async Task AutoSaveFT(int matchId)
    {
        var s = scoreInputs[matchId];
        await GameService.UpdateScoreAsync(
            matchId, s.Home, s.Away, s.IsOvertime,
            s.HomeFullTime, s.AwayFullTime);
        if (tournament != null)
            matches = await GameService.GetMatchesByTournamentAsync(tournament.Id);

        ftSaved.Add(matchId);
        justSavedFT.Add(matchId);
        StateHasChanged();
        await Task.Delay(1500);
        justSavedFT.Remove(matchId);
        StateHasChanged();
    }
}
