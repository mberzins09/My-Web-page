@page "/prognozes/{Slug}/mypredictions"
@rendermode InteractiveServer
@using MartinsWeb.Services
@using MartinsWeb.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject GameService GameService
@inject UserContextService UserContext

<h3>📋 My Predictions — @(tournament?.Name ?? "...")</h3>

<AuthorizeView>
    <NotAuthorized>
        <p>Please <a href="/login">login</a> to make predictions.</p>
    </NotAuthorized>
</AuthorizeView>

<AuthorizeView>
    <Authorized>
        @if (tournament == null)
        {
            <p class="text-danger">Tournament not found.</p>
        }
        else if (games == null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="mb-3 d-flex flex-wrap gap-2">
                <button class="btn btn-sm @(selectedStage == null ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => selectedStage = null">
                    All
                </button>
                @foreach (var stage in stages)
                {
                    <button class="btn btn-sm @(selectedStage == stage ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => selectedStage = stage">
                        @stage
                    </button>
                }
            </div>

            @if (!filteredGames.Any())
            {
                <p>No games in this stage yet.</p>
            }
            else
            {
                <div class="pred-total mb-2">
                    <strong>Total points shown:</strong>
                    <strong class="ms-1">@totalPoints pts</strong>
                </div>

                <div class="tt-grid pred-grid">
                    @foreach (var game in filteredGames)
                    {
                        var pred   = predictions.FirstOrDefault(p => p.GameId == game.Id);
                        var isPast = game.GameDate < LatviaTime;
                        EnsureEditValue(game.Id, pred);

                        int? earnedPoints = null;
                        if (pred != null && game.HomeScore != null && game.AwayScore != null)
                            earnedPoints = CalcPoints(pred, game);

                        <div class="tt-card pred-card">
                            <div class="pred-card-top">
                                <span class="pred-date">@game.GameDate.ToLocalTime().ToString("MMM dd HH:mm")</span>
                                <span class="pred-match">@game.HomeTeam vs @game.AwayTeam</span>
                                <span class="pred-stage">@game.Stage</span>
                            </div>
                            <div class="pred-card-bottom">
                                <span class="pred-input-col">
                                    @if (!isPast)
                                    {
                                        var calcType = tournament?.PointsCalculationType ?? "Football";
                                        var isHockeyType = calcType == "Hockey" || calcType == "Hockey2";
                                        var isFootball2Playoff = calcType == "Football2"
                                            && !game.Stage.Contains("grupa", StringComparison.OrdinalIgnoreCase)
                                            && !game.Stage.Contains("group", StringComparison.OrdinalIgnoreCase);
                                        var canOT = (isHockeyType || isFootball2Playoff)
                                                    && Math.Abs(editValues[game.Id].Home - editValues[game.Id].Away) == 1;
                                        <div class="d-flex align-items-center gap-1 flex-nowrap">
                                            <input class="form-control pred-score-input" type="number" min="0" max="20"
                                                   value="@editValues[game.Id].Home"
                                                   @onchange="async e => { editValues[game.Id].Home = ParseScore(e); if (Math.Abs(editValues[game.Id].Home - editValues[game.Id].Away) != 1) editValues[game.Id].IsOvertime = false; await AutoSavePrediction(game.Id); }" />
                                            <span class="pred-colon">:</span>
                                            <input class="form-control pred-score-input" type="number" min="0" max="20"
                                                   value="@editValues[game.Id].Away"
                                                   @onchange="async e => { editValues[game.Id].Away = ParseScore(e); if (Math.Abs(editValues[game.Id].Home - editValues[game.Id].Away) != 1) editValues[game.Id].IsOvertime = false; await AutoSavePrediction(game.Id); }" />
                                            @if (canOT)
                                            {
                                                <div class="form-check form-check-inline ms-1 mb-0" title="Overtime?">
                                                    <input class="form-check-input" type="checkbox" id="ot_@(game.Id)"
                                                           checked="@editValues[game.Id].IsOvertime"
                                                           @onchange="async e => { editValues[game.Id].IsOvertime = (bool)(e.Value ?? false); await AutoSavePrediction(game.Id); }" />
                                                    <label class="form-check-label small" for="ot_@(game.Id)">OT</label>
                                                </div>
                                            }
                                            @if (justSaved.Contains(game.Id))
                                            {
                                                <span class="text-success ms-1" title="Saved!">✓</span>
                                            }
                                            else if (pred == null)
                                            {
                                                <button class="btn btn-sm btn-outline-success ms-1 p-0 px-1"
                                                        style="font-size:.8rem; line-height:1.4"
                                                        title="Save prediction"
                                                        @onclick="async () => await AutoSavePrediction(game.Id)">💾</button>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        @if (pred != null)
                                        {
                                            <span class="pred-past">@pred.PredictedHomeScore : @pred.PredictedAwayScore@(pred.PredictedIsOvertime ? " OT" : "")</span>
                                        }
                                        else
                                        {
                                            <span class="text-white">—</span>
                                        }
                                    }
                                </span>
                                <span class="pred-right-col">
                                    <span class="pred-result">
                                        @if (game.HomeScore != null)
                                        {
                                            <strong>@game.HomeScore:@game.AwayScore@(game.IsOvertime ? " OT" : "")</strong>
                                        }
                                        else
                                        {
                                            <span class="text-white">TBD</span>
                                        }
                                    </span>
                                    <span class="pred-pts">
                                        @if (earnedPoints != null)
                                        {
                                            <span class="badge @PointsBadgeClass(earnedPoints.Value)">@earnedPoints</span>
                                        }
                                        else
                                        {
                                            <span class="text-white">—</span>
                                        }
                                    </span>
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }

            @* ── My Predicted Group Standings ────────────────────────────────── *@
            @if (selectedStage != null && selectedStage.Contains("grupa", StringComparison.OrdinalIgnoreCase))
            {
                var gamesInGroup = (games ?? new()).Where(g => g.Stage == selectedStage).ToList();
                var teams = GetTeams(gamesInGroup);

                @if (teams.Any())
                {
                    <h5 class="mt-4">📊 My Predicted Standings — @selectedStage</h5>
                    <p class="text-white" style="font-size:.8rem">Based on your predictions for this group.</p>

                    var sorted = ComputePredictedStandings(teams, gamesInGroup)
                        .OrderByDescending(s => s.Points)
                        .ThenByDescending(s => s.GoalDiff)
                        .ThenByDescending(s => s.GoalsFor)
                        .ToList();

                    <div class="table-responsive">
                        <table class="table table-bordered table-sm group-table mb-0">
                            <thead>
                                <tr class="table-primary">
                                    <th class="team-name-col"></th>
                                    @foreach (var s in sorted)
                                    {
                                        <th class="text-center team-col" title="@s.Team">@s.Team</th>
                                    }
                                    <th class="text-center stat-col">Pts</th>
                                    <th class="text-center stat-col">±</th>
                                    <th class="text-center stat-col">Vieta</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < sorted.Count; i++)
                                {
                                    var row   = sorted[i];
                                    var place = i + 1;
                                    <tr class="table-dark">
                                        <td class="team-name-col"><strong>@row.Team</strong></td>
                                        @foreach (var col in sorted)
                                        {
                                            @if (row.Team == col.Team)
                                            {
                                                <td class="black-cell"></td>
                                            }
                                            else
                                            {
                                                var game = FindGame(gamesInGroup, row.Team, col.Team);
                                                var pred = game != null ? predictions.FirstOrDefault(p => p.GameId == game.Id) : null;
                                                <td class="text-center score-cell">
                                                    @if (pred != null && game != null)
                                                    {
                                                        int myG  = game.HomeTeam == row.Team ? pred.PredictedHomeScore : pred.PredictedAwayScore;
                                                        int oppG = game.HomeTeam == row.Team ? pred.PredictedAwayScore : pred.PredictedHomeScore;
                                                        <span>@myG:@oppG</span>
                                                    }
                                                </td>
                                            }
                                        }
                                        <td class="text-center stat-col"><strong>@row.Points</strong></td>
                                        <td class="text-center stat-col @GoalDiffClass(row.GoalDiff)">
                                            @(row.GoalDiff > 0 ? "+" : "")@row.GoalDiff
                                        </td>
                                        <td class="text-center stat-col"><strong>@place</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-white mt-2" style="font-size:.8rem">
                        Sorted by: Points → Goal difference → Goals scored
                    </p>
                }
            }

            @if (saveError != null)
            {
                <p class="text-danger mt-2">@saveError</p>
            }
        }
    </Authorized>
</AuthorizeView>

@code {
    [Parameter] public string Slug { get; set; } = "";

    Tournament?  tournament;
    List<Game>?  games;
    List<Prediction> predictions = new();
    Dictionary<int, ScoreInput> editValues = new();
    HashSet<int> justSaved    = new();
    string?      selectedStage;
    string?      saveError;
    int?         userId;

    DateTime LatviaTime => TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, TimeZoneInfo.FindSystemTimeZoneById("Europe/Riga"));

    List<string> stages => games?
        .Select(g => g.Stage)
        .Where(s => !string.IsNullOrEmpty(s))
        .Distinct()
        .OrderBy(StageOrder)
        .ToList() ?? new();

    List<Game> filteredGames
    {
        get
        {
            var today = LatviaTime.Date.AddDays(-1);
            var all = games?.Where(g => selectedStage == null || g.Stage == selectedStage) ?? Enumerable.Empty<Game>();
            var upcoming = all.Where(g => g.GameDate.Date >= today).OrderBy(g => g.GameDate).ThenBy(g => StageOrder(g.Stage));
            var past = all.Where(g => g.GameDate.Date < today).OrderByDescending(g => g.GameDate);
            return upcoming.Concat(past).ToList();
        }
    }

    int totalPoints => predictions
        .Where(p => p.Game?.HomeScore != null && p.Game?.AwayScore != null)
        .Where(p => selectedStage == null || p.Game.Stage == selectedStage)
        .Sum(p => CalcPoints(p, p.Game));

    int CalcPoints(Prediction p, Game g)
    {
        if (g.HomeScore == null || g.AwayScore == null) return 0;
        return PointsCalculator.Calculate(
            p.PredictedHomeScore, p.PredictedAwayScore, p.PredictedIsOvertime,
            g.HomeScore.Value, g.AwayScore.Value, g.IsOvertime,
            g.Stage,
            tournament?.PointsCalculationType ?? "Football");
    }

    int StageOrder(string stage) => stage.ToLower() switch
    {
        var s when s.Contains("grupa") => 0,
        "round of 32"   => 1,
        "round of 16"   => 2,
        "quarter-final" => 3,
        "semi-final"    => 4,
        "final"         => 5,
        _               => 99
    };

    string PointsBadgeClass(int pts)
    {
        int max = (tournament?.PointsCalculationType) switch
        {
            "Hockey"                => 10,
            "Hockey2" or "Football2" => 7,
            _                       => 7
        };
        int pct = max > 0 ? pts * 100 / max : 0;
        return pct switch
        {
            100    => "bg-warning text-dark",
            >= 50  => "bg-success",
            >= 25  => "bg-info text-dark",
            > 0    => "bg-secondary",
            _      => "bg-danger"
        };
    }

    int ParseScore(ChangeEventArgs e)
    {
        int.TryParse(e.Value?.ToString(), out var v);
        return Math.Max(0, Math.Min(20, v));
    }

    protected override async Task OnInitializedAsync()
    {
        tournament = await GameService.GetTournamentBySlugAsync(Slug);
        if (tournament == null) return;

        userId = await UserContext.GetUserIdAsync();
        games  = await GameService.GetMatchesByTournamentAsync(tournament.Id);

        if (userId != null)
        {
            predictions = await GameService.GetUserPredictionsByTournamentAsync(userId.Value, tournament.Id);
            foreach (var pred in predictions)
                editValues[pred.GameId] = new ScoreInput
                {
                    Home       = pred.PredictedHomeScore,
                    Away       = pred.PredictedAwayScore,
                    IsOvertime = pred.PredictedIsOvertime
                };
        }
    }

    void EnsureEditValue(int gameId, Prediction? pred)
    {
        if (!editValues.ContainsKey(gameId))
            editValues[gameId] = new ScoreInput
            {
                Home       = pred?.PredictedHomeScore ?? 0,
                Away       = pred?.PredictedAwayScore ?? 0,
                IsOvertime = pred?.PredictedIsOvertime ?? false
            };
    }

    async Task AutoSavePrediction(int gameId)
    {
        if (userId == null || tournament == null) return;
        saveError = null;
        try
        {
            var s = editValues[gameId];
            await GameService.SavePredictionAsync(userId.Value, gameId, s.Home, s.Away, s.IsOvertime);
            predictions = await GameService.GetUserPredictionsByTournamentAsync(userId.Value, tournament.Id);

            justSaved.Add(gameId);
            StateHasChanged();
            await Task.Delay(1500);
            justSaved.Remove(gameId);
            StateHasChanged();
        }
        catch
        {
            saveError = "Failed to save. Please try again.";
        }
    }

    // ── Group table helpers ───────────────────────────────────────────────────

    record TeamStanding(string Team, int Points, int GoalDiff, int GoalsFor);

    List<string> GetTeams(List<Game> gamesInGroup) =>
        gamesInGroup.SelectMany(g => new[] { g.HomeTeam, g.AwayTeam })
             .Where(t => !string.IsNullOrEmpty(t))
             .Distinct()
             .ToList();

    Game? FindGame(List<Game> gamesInGroup, string a, string b) =>
        gamesInGroup.FirstOrDefault(g =>
            (g.HomeTeam == a && g.AwayTeam == b) ||
            (g.HomeTeam == b && g.AwayTeam == a));

    string GoalDiffClass(int diff) => diff switch { > 0 => "text-success", < 0 => "text-danger", _ => "" };

    // Standings based on the current user's own predictions (all games, not just started)
    List<TeamStanding> ComputePredictedStandings(List<string> teams, List<Game> gamesInGroup)
    {
        bool isHockey = tournament?.PointsCalculationType == "Hockey"
                     || tournament?.PointsCalculationType == "Hockey2";
        return teams.Select(team =>
        {
            int pts = 0, gf = 0, ga = 0;
            foreach (var g in gamesInGroup.Where(g => g.HomeTeam == team || g.AwayTeam == team))
            {
                var pred = predictions.FirstOrDefault(p => p.GameId == g.Id);
                if (pred == null) continue;
                int myG  = g.HomeTeam == team ? pred.PredictedHomeScore : pred.PredictedAwayScore;
                int oppG = g.HomeTeam == team ? pred.PredictedAwayScore : pred.PredictedHomeScore;
                gf += myG; ga += oppG;
                if (isHockey)
                    pts += myG > oppG ? (pred.PredictedIsOvertime ? 2 : 3)
                         : myG < oppG ? (pred.PredictedIsOvertime ? 1 : 0)
                         : 1; // draw shouldn't happen in hockey but safe fallback
                else
                    pts += myG > oppG ? 3 : myG == oppG ? 1 : 0;
            }
            return new TeamStanding(team, pts, gf - ga, gf);
        }).ToList();
    }
}
