@page "/"

<PageTitle>Home</PageTitle>

<div class="container py-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Mārtiņš Bērziņš</h1>
        <p class="lead text-muted">
            Personal website showcasing my work, projects, and ideas.
        </p>

        <div class="mt-4">
            <a class="btn btn-primary btn-lg me-2" href="/cv">View CV</a>
            <a class="btn btn-outline-secondary btn-lg" href="/lgtf">My Projects</a>
        </div>
    </div>

    <!-- About Section -->
    <div class="row mb-5">
        <div class="col-md-8 offset-md-2 text-center">
            <h3>Welcome 👋</h3>
            <p class="text-muted">
                This is my personal web page where you can explore my professional background,
                browse my projects, and try out applications I've built.
            </p>
        </div>
    </div>

    <!-- Features Section -->
    <div class="row text-center features-section">

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm feature-card">
                <div class="card-body">
                    <h5 class="card-title">📄 CV</h5>
                    <p class="card-text">
                        Learn more about my experience, skills, and background.
                    </p>
                    <a href="/cv" class="btn btn-outline-primary btn-sm">Open CV</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm feature-card">
                <div class="card-body">
                    <h5 class="card-title">💻 Projects</h5>
                    <p class="card-text">
                        Explore my favorite project — a .NET MAUI application — with more coming soon.
                    </p>
                    <a href="/lgtf" class="btn btn-outline-light btn-sm">View Projects</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm feature-card">
                <div class="card-body">
                    <h5 class="card-title">🎮 Prediction Game</h5>
                    <p class="card-text">
                        Register and log in to participate in prediction games and track your results.
                    </p>
                    <a href="/prognozes/worldcup2026/leaderboard" class="btn btn-outline-primary btn-sm">Get Started</a>
                </div>
            </div>
        </div>
    </div>
</div>
